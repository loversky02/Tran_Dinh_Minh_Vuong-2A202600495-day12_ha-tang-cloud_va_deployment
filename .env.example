# ============================================================
# Environment Variables Template
# Copy this file to .env and fill in your values
# ============================================================

# Server Configuration
PORT=8000
ENVIRONMENT=production

# API Security
AGENT_API_KEY=your-secret-api-key-here

# CORS Configuration (comma-separated)
ALLOWED_ORIGINS=*

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10

# OpenAI Configuration (Optional - will use mock if not set)
# OPENAI_API_KEY=sk-your-openai-key-here
# LLM_MODEL=gpt-4o-mini
# MAX_TOKENS=500

# Logging
LOG_LEVEL=INFO

# ============================================================
# Optional: For future enhancements
# ============================================================

# Redis (for scalable rate limiting and sessions)
# REDIS_URL=redis://localhost:6379/0
# Note: If not set, will fallback to in-memory rate limiting

# JWT Authentication
# JWT_SECRET=your-jwt-secret-here

# Cost Guard
# MONTHLY_BUDGET_USD=10
# DAILY_BUDGET_USD=1

# LLM API (if using real LLM instead of mock)
# OPENAI_API_KEY=sk-your-openai-key-here
# LLM_MODEL=gpt-4o-mini
# MAX_TOKENS=500

# ============================================================
# Notes:
# - Never commit .env file to git
# - Keep secrets secure
# - Use different values for dev/staging/production
# ============================================================
